<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[;; agentes, entidades del problema
breed [sanos sano]
breed [pacientes paciente]
breed [fuegos fuego]
breed [obstaculos obstaculo] 

;; variable global
globals [
  velocidadhumo
]

;; atributos:
sanos-own [
  velocidad
  energia
  conoce-edificio
]

pacientes-own [
  velocidad
  energia
  conoce-edificio
]

fuegos-own [
  radio
  velocidad
  tiempo
]

obstaculos-own [
]

patches-own [
  pared
  salida
  distancia
  quemados
  humo
]


;; inicializar
to setup
  clear-all
  set velocidadhumo 2.27
  
  ask patches [
    set pcolor black
    set pared true
    set salida false
    set quemados false
    set humo 0
  ]
  
  ;; barra horizontal de la T (parte ancha de abajo)
  ask patches with [pxcor >= -31 and pxcor <= 32 and pycor >= -15.3 and pycor <= 0] [
    set pcolor white
    set pared false
  ]
  ;; barra vertical de la T (parte angosta de arriba)
  ask patches with [pxcor >= -10 and pxcor <= 10 and pycor >= 0 and pycor <= 17] [
    set pcolor white
    set pared false
  ]
  ;; salida 2 (arriba)
  ask patches with [pxcor >= -2 and pxcor <= 2 and pycor >= 18 and pycor <= 19] [
    set pcolor green
    set pared false
    set salida true
  ]
  ;; salida 1 (abajo)
  ask patches with [pxcor >= -2 and pxcor <= 2 and pycor >= -17 and pycor <= -16] [
    set pcolor green
    set pared false
    set salida true
  ]
    ;; salida 3 (lateral derecha)
  ask patches with [pycor >= -8 and pycor <= -6 and pxcor >= 33 and pxcor <= 34] [
    set pcolor green
    set pared false
    set salida true
  ]
    ;; salida 4 (lateral izqierda)
  ask patches with [pycor >= -8 and pycor <= -6 and pxcor >= -33 and pxcor <= -32] [
    set pcolor green
    set pared false
    set salida true
  ]
  ;; paredes internas que dividen habitaciones (barra horizontal)
  ;; verticales que bajan desde el techo de la barra horizontal
  ask patches with [pycor >= -5.7 and pycor <= 0 and (pxcor = -26 or pxcor = -21 or pxcor = -16 
      or pxcor = -11 or pxcor = 11 or pxcor = 17 or pxcor = 22 or pxcor = 27)] [
    set pcolor black
    set pared true
  ]
  ;; paredes internas que suben desde el piso de la barra horizontal
  ask patches with [pycor >= -15 and pycor <= -9 and (pxcor = -26 or pxcor = -21 or pxcor = -16 
      or pxcor = -11 or pxcor = 11 or pxcor = 17 or pxcor = 22 or pxcor = 27)] [
    set pcolor black
    set pared true
  ]
    ;; paredes internas de la zona sur que generan espacio de la puerta de la habitación
  ask patches with [(pycor = -9 or pycor = -5) and ((pxcor >= -31 and pxcor <= -29)
      or (pxcor >= -23 and pxcor <= -19) or (pxcor >= -13 and pxcor <= -11) or (pxcor >= 11 and pxcor <= 14) 
      or (pxcor >= 20 and pxcor <= 24 ) or (pxcor >= 30 and pxcor <= 32))] [
    set pcolor black
    set pared true
  ]

;; paredes internas de la zona norte
  ask patches with [(abs pxcor >= 5 and abs pxcor <= 10) and (pycor = 1 or pycor = 5 or pycor = 9 or pycor = 13)] [
    set pcolor black
    set pared true
  ]
  ;; paredes internas de la zona norte que generan espacio de la puerta de la habitación
  ask patches with [(abs pxcor = 5) and ((pycor >= 1 and pycor <= 2) or (pycor >= 8 and pycor <= 10) or (pycor >= 16 and pycor <= 17))] [
    set pcolor black
    set pared true
  ]
  
  ;; crear obstaculos (camas, equipos medicos)
  create-obstaculos 15 [
    move-to one-of patches with [not pared and not salida and not any? turtles-here]
    set shape "square"
    set color gray
    set size 1
  ]

  ask obstaculos [
    ask patch-here [set pared true]
  ]
  
  ;; crear fuego en un rincon aleatorio del edificio
  create-fuegos 1 [
    move-to one-of patches with [not pared and not salida]
    set shape "circle"
    set color orange
    set size 1
    set radio 3
    set velocidad 1.3
    set tiempo 0
    ;; empezar a quemar el patch inicial
    ask patch-here [
      set quemados true
      set pcolor red
    ]
  ]

  ;; crear sanos (violeta)
  create-sanos num-sanos [
    move-to one-of patches with [not pared and not salida and not any? turtles-here]
    set shape "person"
    set color violet
    set size 1.5

    set energia 50 + random 101
    set conoce-edificio one-of [true false]

    ;; selección en la interfaz externa
    if conocimiento-edificio = "Todos"     [ set conoce-edificio true ]
    if conocimiento-edificio = "Ninguno"   [ set conoce-edificio false ]
    if conocimiento-edificio = "Aleatorio" [ set conoce-edificio one-of [true false] ]

    ;; asignación de velocidad según corresponda
    ifelse conoce-edificio
      [ set velocidad 2.0 + random-float 1.5 ] ;; Sano - Conoce
      [ set velocidad 1.6 + random-float 1.5 ] ;; Sano - No conoce
  ]

  ;; crear pacientes (azul)
  create-pacientes num-pacientes [
    move-to one-of patches with [not pared and not salida and not any? turtles-here]
    set shape "person"
    set color blue
    set size 1.5

    set energia (50 + random 101) * 0.5
    set conoce-edificio one-of [true false]

    ;; selección en la interfaz externa
    if conocimiento-edificio = "Todos"     [ set conoce-edificio true ]
    if conocimiento-edificio = "Ninguno"   [ set conoce-edificio false ]
    if conocimiento-edificio = "Aleatorio" [ set conoce-edificio one-of [true false] ]

    ;; asignación de velocidad según corresponda
    ifelse conoce-edificio
      [ set velocidad 1.5 + random-float 1.5 ] ;; Paciente - Conoce
      [ set velocidad 1.0 + random-float 1.5 ] ;; Paciente - No conoce
  ]
  calcular-distancias
  reset-ticks
end

;; Procedimientos, funciones:

;; calcula desde cada salida cuantos pasos cuesta llegar a cada patch
to calcular-distancias
  ;; inicializar: salidas en 0, todo lo demas en infinito
  ask patches [ set distancia (count patches)]
  ask patches with [salida] [ set distancia 0 ]

  ;; distancia hacia afuera 
  let cambiapatch true
  while [cambiapatch] [
    set cambiapatch false
    ask patches with [not pared and distancia < count patches] [
      ask neighbors with [not pared and distancia > [distancia] of myself + 1] [
        set distancia [distancia] of myself + 1
        set cambiapatch true
      ]
    ]
  ]
end

;; bajar por el campo de distancias hacia la salida
to mover
  if energia <= 0 [ stop ]

  let velocidadactual velocidad
  if [humo] of patch-here > 1 [
    set velocidadactual velocidad * 0.5
  ]

  repeat round velocidadactual [
    let patchlibre neighbors with [not pared and not any? sanos-here with [color != green and color != black] and not any? pacientes-here with [color != green and color != black]]
    if any? patchlibre [
      ifelse conoce-edificio
        [ ;; va directo a la salida 
          let patchaocupar min-one-of patchlibre [distancia]
          if [distancia] of patchaocupar < distancia [
            move-to patchaocupar
          ]
        ]
        [ ;; si no, se desorienta y va al azar
          ifelse random 100 < 50
            [ ;; 50% de las veces se mueve al azar 
              move-to one-of patchlibre
            ]
            [ ;; 50% de las veces logra salir rapido
              let patchaocupar min-one-of patchlibre [distancia]
              if [distancia] of patchaocupar < distancia [
                move-to patchaocupar
              ]
            ]
        ]
    ]
  ]

  if salida [
    set energia 0
    set color green    ;; verde escapo con vida
    stop
  ]
end

;; el fuego son agentes que se reproducen, no una avance uniforme
;; en el GAML esto se hace con do wander + create feu when: flip(debuter)
to propagar-fuego
  ask fuegos [
    ;; si todos los patches alrededor ya estan quemados o son pared,
    ;; este fuego ya no puede expandir nada: es interior, se elimina.
    ;; si todavia tiene vecinos sin quemar, es frente activo y sigue vivo. 
    ;; NO existe ningún vecino que esté libre y sin quemar
    if not any? neighbors with [not pared and not quemados and not salida] [
      die
    ]

    right random 360
    if not [pared] of patch-ahead 1 [
      forward 1
    ]
    ask patch-here [
      set quemados true
      set pcolor red
    ]
    if random 100 < prob-fuego [
      hatch-fuegos 1 [
        right random 360
        if not [pared] of patch-ahead 1 [
          forward 1
        ]
      ]
    ]
  ]
end

;; el humo sale de los patches quemados y se mueve a los vecinos con diffuse del modelo de particlesmoke de netlogo
to propagar-humo 
  ask patches with [quemados][
    set humo 100
  ]
  ;; el humo avanza patches por tick (2.27 m/s) 
  repeat velocidadhumo [
    diffuse humo 0.5
  ] 
  ask patches with [humo > 0][
    set humo humo - 1
    if humo < 0 [set humo 0]
  ]
  ;; mientras mas humo, mas gris la celda
  ask patches with [not pared and not quemados and not salida] [
    ifelse humo > 1
      [ set pcolor scale-color gray humo 0 100 ]
      [ set pcolor white ]
  ]
  
end

;; fuego y humo afectan a los agentes (people_mourir y malade_mourir del GAML)
to dano
  ask (turtle-set sanos pacientes) [
    if color = green [ stop ]
    ;; en el fuego
    if [quemados] of patch-here [
      set energia energia - 10
    ]
    ;; en el humo 0 a 3 por tick segun paper
    if [humo] of patch-here > 1 [
      set energia energia - random 4
    ]
    ;; sin energia se muere
    if energia <= 0 [
      set energia 0
      set color black
    ]
  ]
end

to graficos
  ;; primer grafico de la poblacion
  set-current-plot "General"
  clear-plot
  set-current-plot-pen "vivos"
  plotxy 0 (count (turtle-set sanos pacientes) with [color = green])
  set-current-plot-pen "muertos"
  plotxy 1 (count (turtle-set sanos pacientes) with [color = black])

  ;; segundo grafico estado de salud 
  set-current-plot "Salud"
  clear-plot
  set-current-plot-pen "vivos-pacientes"
  plotxy 0 (count pacientes with [color = green])
  set-current-plot-pen "muertos-pacientes"
  plotxy 1 (count pacientes with [color = black])
  set-current-plot-pen "vivos-sanos"
  plotxy 2 (count sanos with [color = green])
  set-current-plot-pen "muertos-sanos"
  plotxy 3 (count sanos with [color = black])
  
  ;; tercer grafico evacuación por conocimiento del edificio, no considera estatus de salud
  set-current-plot "Conocimiento edificio (no considera salud)"
  clear-plot
  set-current-plot-pen "Vivos, conoce edificio"
  plotxy 0 (count (turtle-set sanos pacientes) with [color = green and conoce-edificio])
  set-current-plot-pen "Muertos, conoce edificio"
  plotxy 1 (count (turtle-set sanos pacientes) with [color = black and conoce-edificio])
  set-current-plot-pen "Vivos, no conoce edificio"
  plotxy 2 (count (turtle-set sanos pacientes) with [color = green and not conoce-edificio])
  set-current-plot-pen "Muertos, no conoce edificio"
  plotxy 3 (count (turtle-set sanos pacientes) with [color = black and not conoce-edificio])

  ;; cuarto grafico evacuación por conocimiento del edificio considerando estatus de salud
  set-current-plot "Conocimiento edificio"
  clear-plot
  set-current-plot-pen "Pacientes, no conoce edificio"
  plotxy 0 (count pacientes with [not conoce-edificio]) 
  set-current-plot-pen "Sanos, no conocen edificio"
  plotxy 1 (count sanos with [not conoce-edificio])
  set-current-plot-pen "Vivos. Sanos, conocen edificio"
  plotxy 2 (count sanos with [color = green and conoce-edificio])
  set-current-plot-pen "Vivos. Sanos, no conocen edificio"
  plotxy 3 (count sanos with [color = green and not conoce-edificio])
  set-current-plot-pen "Vivos. Pacientes, conocen edificio"
  plotxy 4 (count pacientes with [color = green and conoce-edificio])
  set-current-plot-pen "Vivos. Pacientes, no conocen edificio"
  plotxy 5 (count pacientes with [color = green and not conoce-edificio]) 
  set-current-plot-pen "Muertos. Sanos, conocen edificio"
  plotxy 6 (count sanos with [color = black and conoce-edificio])
  set-current-plot-pen "Muertos. Sanos, no conocen edificio"
  plotxy 7 (count sanos with [color = black and not conoce-edificio])
  set-current-plot-pen "Muertos. Pacientes, conocen edificio"
  plotxy 8 (count pacientes with [color = black and conoce-edificio])
  set-current-plot-pen "Muertos. Pacientes, no conocen edificio"
  plotxy 9 (count pacientes with [color = black and not conoce-edificio])
  
end

;; iniciar simulacion
to go
  tick 

  if not any? sanos and not any? pacientes [ stop ]
  if not any? (turtle-set sanos pacientes) with [energia > 0] [
    ask fuegos [ die ]
    graficos
    stop
  ] 
  
  propagar-fuego
  propagar-humo
  dano
  ask sanos     [ mover ]
  ask pacientes [ mover ]
  
end]]></code>
  <widgets>
    <view x="325" wrappingAllowedX="true" y="25" frameRate="30.0" minPycor="-20" height="514" showTickCounter="true" patchSize="10.0" fontSize="10" wrappingAllowedY="true" width="814" tickCounterLabel="ticks" maxPycor="30" updateMode="0" maxPxcor="40" minPxcor="-40"></view>
    <slider x="40" step="1" y="50" max="100" width="250" display="prob-fuego" height="50" min="0" direction="Horizontal" default="95.0" variable="prob-fuego"></slider>
    <monitor x="1160" precision="17" y="300" height="60" fontSize="11" width="115" display="Vivos-pacientes">count pacientes with [color = green]</monitor>
    <monitor x="1160" precision="17" y="365" height="60" fontSize="11" width="115" display="Muertos-pacientes">count pacientes with [color = black]</monitor>
    <monitor x="1160" precision="17" y="150" height="60" fontSize="11" width="100" display="Muertos">count (turtle-set sanos pacientes) with [color = black]</monitor>
    <monitor x="1160" precision="17" y="75" height="60" fontSize="11" width="100" display="Vivos">count (turtle-set sanos pacientes) with [color = green]</monitor>
    <monitor x="1160" precision="17" y="430" height="60" fontSize="11" width="115" display="Vivos-sanos">count sanos with [color = green]</monitor>
    <monitor x="1160" precision="17" y="495" height="60" fontSize="11" width="115" display="Muertos-sanos">count sanos with [color = black]</monitor>
    <chooser x="40" y="215" height="60" variable="conocimiento-edificio" current="0" width="250" display="conocimiento-edificio">
      <choice type="string" value="Aleatorio"></choice>
      <choice type="string" value="Todos"></choice>
      <choice type="string" value="Ninguno"></choice>
    </chooser>
    <button x="175" y="285" height="40" disableUntilTicks="false" forever="true" kind="Observer" width="55">go</button>
    <monitor x="2270" precision="17" y="555" height="60" fontSize="11" width="175" display="Muertos. Pacientes, no conocen edificio">count pacientes with [color = black and not conoce-edificio]</monitor>
    <monitor x="2270" precision="17" y="490" height="60" fontSize="11" width="175" display="Muertos. Pacientes, conocen edificio">count pacientes with [color = black and conoce-edificio]</monitor>
    <monitor x="2270" precision="17" y="425" height="60" fontSize="11" width="175" display="Muertos. Sanos, no conocen edificio">count sanos with [color = black and not conoce-edificio]</monitor>
    <monitor x="2270" precision="17" y="360" height="60" fontSize="11" width="175" display="Muertos. Sanos, conocen edificio">count sanos with [color = black and conoce-edificio]</monitor>
    <monitor x="2270" precision="17" y="295" height="60" fontSize="11" width="175" display="Sanos, no conocen edificio">count sanos with [not conoce-edificio]</monitor>
    <monitor x="2070" precision="17" y="555" height="60" fontSize="11" width="175" display="Vivos. Pacientes, no conocen edificio">count pacientes with [color = green and not conoce-edificio]</monitor>
    <monitor x="2070" precision="17" y="490" height="60" fontSize="11" width="175" display="Vivos. Pacientes, conocen edificio">count pacientes with [color = green and conoce-edificio]</monitor>
    <monitor x="2070" precision="17" y="425" height="60" fontSize="11" width="175" display="Vivos. Sanos, no conocen edificio">count sanos with [color = green and not conoce-edificio]</monitor>
    <monitor x="2070" precision="17" y="360" height="60" fontSize="11" width="175" display="Vivos. Sanos, conocen edificio">count sanos with [color = green and conoce-edificio]</monitor>
    <monitor x="2070" precision="17" y="295" height="60" fontSize="11" width="175" display="Pacientes, no conoce edificio">count pacientes with [not conoce-edificio]</monitor>
    <plot x="1675" autoPlotX="true" yMax="50.0" autoPlotY="true" y="25" xMin="0.0" height="260" legend="false" xMax="4.0" yMin="0.0" width="385" display="Conocimiento edificio (no considera salud)">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="1" display="Vivos, conoce edificio" color="-7500403" legend="true">
        <setup></setup>
        <update></update>
      </pen>
      <pen interval="1.0" mode="1" display="Muertos, conoce edificio" color="-2674135" legend="true">
        <setup></setup>
        <update></update>
      </pen>
      <pen interval="1.0" mode="1" display="Vivos, no conoce edificio" color="-955883" legend="true">
        <setup></setup>
        <update></update>
      </pen>
      <pen interval="1.0" mode="1" display="Muertos, no conoce edificio" color="-6459832" legend="true">
        <setup></setup>
        <update></update>
      </pen>
    </plot>
    <plot x="1290" autoPlotX="true" yMax="50.0" autoPlotY="true" y="25" xMin="0.0" height="260" legend="false" xMax="2.0" yMin="0.0" width="375" display="General">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="1" display="vivos" color="-11085214" legend="true">
        <setup></setup>
        <update></update>
      </pen>
      <pen interval="1.0" mode="1" display="muertos" color="-2139308" legend="true">
        <setup></setup>
        <update></update>
      </pen>
    </plot>
    <plot x="1290" autoPlotX="true" yMax="50.0" autoPlotY="true" y="295" xMin="0.0" height="265" legend="false" xMax="4.0" yMin="0.0" width="375" display="Salud">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="1" display="vivos-sanos" color="-14835848" legend="true">
        <setup></setup>
        <update></update>
      </pen>
      <pen interval="1.0" mode="1" display="vivos-pacientes" color="-11221820" legend="true">
        <setup></setup>
        <update></update>
      </pen>
