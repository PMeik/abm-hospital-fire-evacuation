      <pen interval="1.0" mode="1" display="muertos-pacientes" color="-15582384" legend="true">
        <setup></setup>
        <update></update>
      </pen>
    </plot>
    <monitor x="1690" precision="17" y="300" height="60" fontSize="11" width="160" display="Vivos, conocen edificio">count (turtle-set sanos pacientes) with [color = green and conoce-edificio]</monitor>
    <monitor x="1690" precision="17" y="365" height="60" fontSize="11" width="160" display="Muertos, conocen edificio">count (turtle-set sanos pacientes) with [color = black and conoce-edificio]</monitor>
    <monitor x="1690" precision="17" y="430" height="60" fontSize="11" width="160" display="Vivos, no conocen edificio">count (turtle-set sanos pacientes) with [color = green and not conoce-edificio]</monitor>
    <monitor x="1690" precision="17" y="495" height="60" fontSize="11" width="160" display="Muertos, no conocen edificio">count (turtle-set sanos pacientes) with [color = black and not conoce-edificio]</monitor>
    <plot x="2070" autoPlotX="true" yMax="50.0" autoPlotY="true" y="25" xMin="0.0" height="260" legend="false" xMax="10.0" yMin="0.0" width="375" display="Conocimiento edificio">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="1" display="Pacientes, no conoce edificio" color="-10873583" legend="true">
        <setup></setup>
